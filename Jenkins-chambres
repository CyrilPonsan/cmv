pipeline {
    agent any

    tools {
        nodejs 'nodejs'
    }

    environment {
        DOCKERHUB_CREDENTIALS = credentials('cmv-dockerhub')
        IMAGE_CHAMBRES = "firizgoude/cmv_chambres"
        IMAGE_CHAMBRES_TAG = "chambres-${env.BUILD_NUMBER}"
        BRANCH_NAME = "${env.GIT_BRANCH.split('/').last()}"
        EC2_SERVER = credentials("ec2-host")
        EC2_USER = credentials("ec2-username")
        SSH_CREDENTIALS = credentials('cmv-ssh-key')
        PATH = "/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin" 
    }

    stages {
        stage("Checkout") {
            steps {
                checkout scm
                script {
                    echo "Current branch is ${BRANCH_NAME}"
                }
            }
        }
        stage('Build Image') {
            steps {
                dir('cmv_chambres') {
                    script {
                        sh "echo 'Starting Docker build...'"
                        sh "docker --version"
                        sh "pwd"
                        sh "ls -la"
                        sh 'docker build --platform linux/amd64 -t "${IMAGE_CHAMBRES}:latest" .'
                        sh "echo 'Docker build completed.'"
                    }
                }
            }
        }
        stage('Push to DockerHub') {
            steps {
                sh 'echo $DOCKERHUB_CREDENTIALS_PSW | docker login -u $DOCKERHUB_CREDENTIALS_USR --password-stdin'
                sh "docker push ${IMAGE_CHAMBRES}:latest"
            }
        }
        stage('Deploy to EC2') {
            steps {
                script {
                    sshagent(credentials: ['cmv-ssh-key']) {
                        sh """
                            ssh -o StrictHostKeyChecking=no \
                                -o UserKnownHostsFile=/dev/null \
                                -o LogLevel=ERROR \
                                ${EC2_USER}@${EC2_SERVER} << 'EOF'
                            
# Login DockerHub sur l'EC2
echo "${DOCKERHUB_CREDENTIALS_PSW}" | docker login -u ${DOCKERHUB_CREDENTIALS_USR} --password-stdin

# Arrêt et suppression
docker stop cmv_patients || true
docker rm cmv_patients || true
docker image rm ${IMAGE_CHAMBRES}:latest || true

# Déploiement
docker compose up -d

# Logout (optionnel, pour la sécu)
docker logout
EOF
                        """
                    }
                }
            }
        }
    }

    post {
        always {
            script {
                node {
                    sh 'docker logout'
                }
            }
        }
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed. Please check the logs.'
        }
    }
}
