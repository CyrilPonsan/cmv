pipeline {
    agent any

    tools {
        nodejs 'nodejs'
    }

    environment {
        IMAGE_CHAMBRES = "firizgoude/cmv_chambres"
        IMAGE_CHAMBRES_TAG = "chambres-${env.BUILD_NUMBER}"
        BRANCH_NAME = "${env.GIT_BRANCH.split('/').last()}"
        // Gateway (bastion) pour le rebond SSH
        GATEWAY_HOST = credentials("ec2-gateway-host")
        GATEWAY_USER = credentials("ec2-gateway-username")
        // Instance privée chambres
        CHAMBRES_HOST = credentials("ec2-chambres-host")
        CHAMBRES_USER = credentials("ec2-chambres-username")
        SSH_CREDENTIALS = credentials('cmv-ssh-key')
        PATH = "/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"
    }

    stages {
        stage("Checkout") {
            steps {
                checkout scm
                script {
                    echo "Current branch is ${BRANCH_NAME}"
                }
            }
        }
        stage('Build Image') {
            steps {
                dir('cmv_chambres') {
                    sh 'docker build --platform linux/amd64 -t "$IMAGE_CHAMBRES:latest" .'
                }
            }
        }
        stage('Push to DockerHub') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'cmv-dockerhub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh '''
                        set +x
                        echo "$DOCKER_PASS" | docker login --quiet -u "$DOCKER_USER" --password-stdin
                        docker push "$IMAGE_CHAMBRES:latest"
                    '''
                }
            }
        }
        stage('Deploy to EC2') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'cmv-dockerhub',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sshagent(credentials: ['cdk-key']) {
                        sh '''
                            set +x
                            ssh -o StrictHostKeyChecking=no \
                                -o UserKnownHostsFile=/dev/null \
                                -o LogLevel=ERROR \
                                -A \
                                -J $GATEWAY_USER@$GATEWAY_HOST \
                                $CHAMBRES_USER@$CHAMBRES_HOST << 'EOF'

echo "$DOCKER_PASS" | docker login --quiet -u "$DOCKER_USER" --password-stdin

docker stop cmv_chambres || true
docker rm cmv_chambres || true
docker image rm "$IMAGE_CHAMBRES:latest" || true

docker compose up -d

docker logout
EOF
                        '''
                    }
                }
            }
        }
    }

    post {
        always {
            sh 'docker logout || true'
            sh 'docker image rm "$IMAGE_CHAMBRES:latest" || true'
        }
        success {
            echo 'Pipeline terminé avec succès.'
        }
        failure {
            echo 'Pipeline échoué. Vérifier les logs.'
        }
    }
}
