# =============================================================================
# CDK Infrastructure Environment Variables
# Copy this file to .env and fill in the values before deploying.
# =============================================================================

# --- AWS CDK Configuration ---
CDK_DEFAULT_ACCOUNT=123456789012
CDK_DEFAULT_REGION=eu-west-1

# --- Database Admin Credentials ---
# Used to create the PostgreSQL admin role on each database instance
DB_ADMIN_USERNAME=admin_user
DB_ADMIN_PASSWORD=secure_admin_password_here

# --- Database CRUD User Credentials ---
# Used to create the limited-privilege CRUD role
DB_CRUD_USERNAME=crud_user
DB_CRUD_PASSWORD=secure_crud_password_here

# --- Database Name ---
DB_NAME=cmv_db

# --- Database Names per Service ---
GATEWAY_POSTGRES_DB=cmv_gateway
PATIENTS_POSTGRES_DB=cmv_patients
CHAMBRES_POSTGRES_DB=cmv_chambres

# --- Application Secrets ---
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256

# --- Token Configuration ---
ACCESS_MAX_AGE=30
REFRESH_MAX_AGE=1440

# --- Inter-Service URLs (used by gateway) ---
PATIENTS_SERVICE=http://localhost:8002/api
CHAMBRES_SERVICE=http://localhost:8003/api

# --- AWS S3 Configuration (used by patients service) ---
AWS_BUCKET_NAME=your_bucket_name
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=eu-west-1

# --- Domain Configuration (used for Nginx server block) ---
DOMAIN=example.com
